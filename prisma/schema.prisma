generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

enum EnrollmentStatus {
  PENDING
  READY
  FAILED
}

enum RecordingStatus {
  UPLOADED
}

enum VoiceProfileKind {
  PURE
  SCENE
}

enum TtsJobStatus {
  PENDING
  READY
  FAILED
}

enum VideoPlatform {
  BILIBILI
}

enum VideoInputType {
  URL
  BV
}

enum VideoSubtitleStatus {
  PENDING
  READY
  UNAVAILABLE
  FAILED
}

enum VideoTranscriptStatus {
  PENDING
  READY
  FAILED
}

enum VideoTranscriptSource {
  SUBTITLE
  ASR
}

enum VideoAnalysisJobStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum SmsScene {
  REGISTER
  LOGIN
}

enum SmsVerificationStatus {
  SENT
  VERIFIED
  FAILED
}

model User {
  id                           String  @id @default(cuid())
  phoneNumber                  String  @unique
  passwordHash                 String?
  phoneVerifiedAt              DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  activePureVoiceEnrollmentId  String?  @unique
  activeSceneVoiceEnrollmentId String?  @unique
}

model AnonymousUser {
  id                           String   @id @default(cuid())
  tokenHash                    String   @unique
  expiresAt                    DateTime
  lastSeenAt                   DateTime @default(now())
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  activePureVoiceEnrollmentId  String?  @unique
  activeSceneVoiceEnrollmentId String?  @unique

  @@index([expiresAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, expiresAt])
}

model SmsVerification {
  id                 String                 @id @default(cuid())
  phoneNumber        String
  scene             SmsScene
  provider         String
  providerBizId    String?
  providerRequestId String?
  providerOutId    String
  codeHash         String?
  status           SmsVerificationStatus @default(SENT)
  verifyAttempts   Int                    @default(0)
  expiresAt       DateTime
  verifiedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([phoneNumber, scene, createdAt])
  @@index([status, expiresAt])
}

model VoiceRecording {
  id              String          @id @default(cuid())
  userId          String?
  anonymousUserId String?
  status          RecordingStatus @default(UPLOADED)
  durationSeconds Float
  originalFilename String?
  inputContentType String
  bucket          String
  objectKey       String
  minioUri        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model VoiceEnrollment {
  id                String           @id @default(cuid())
  recordingId       String
  userId            String?
  anonymousUserId   String?
  profileKind       VoiceProfileKind
  status            EnrollmentStatus @default(PENDING)
  durationSeconds   Float
  originalFilename  String?
  inputContentType String
  voiceId           String?          @unique
  errorMessage     String?
  isInvalidated   Boolean          @default(false)
  bucket           String
  objectKey       String
  minioUri        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([recordingId])
  @@index([profileKind, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model TtsJob {
  id                 String          @id @default(cuid())
  userId             String?
  anonymousUserId    String?
  voiceEnrollmentId  String?
  profileKind        VoiceProfileKind
  voiceIdSnapshot   String
  text             String
  sceneKey         String?
  instruction      String?
  status           TtsJobStatus    @default(PENDING)
  outputContentType String?
  errorMessage    String?
  bucket          String?
  objectKey       String?
  minioUri       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
  @@index([voiceEnrollmentId])
}

model VideoSource {
  id                String                @id @default(cuid())
  platform          VideoPlatform         @default(BILIBILI)
  inputType         VideoInputType
  inputValue        String
  normalizedBvid    String                @unique
  normalizedUrl     String?
  title             String?
  authorName        String?
  authorMid         String?
  coverUrl          String?
  durationSeconds   Float?
  publishTime       DateTime?
  subtitleStatus    VideoSubtitleStatus   @default(PENDING)
  transcriptStatus  VideoTranscriptStatus @default(PENDING)
  transcriptSource  VideoTranscriptSource?
  subtitleText      String?
  transcriptText    String?
  fetchErrorMessage String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model VideoAnalysisJob {
  id               String                 @id @default(cuid())
  userId           String
  videoSourceId    String
  status           VideoAnalysisJobStatus @default(PENDING)
  errorMessage     String?
  summary          String?
  structureSections Json?
  highlights       Json?
  copySuggestions  Json?
  modelName        String?
  promptVersion    String?
  workerId         String?
  lockedAt         DateTime?
  retryCount       Int                    @default(0)
  nextRetryAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([userId, createdAt])
  @@index([videoSourceId, createdAt])
  @@index([status, createdAt])
}
