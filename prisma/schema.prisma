generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

enum EnrollmentStatus {
  PENDING
  READY
  FAILED
}

enum TtsJobStatus {
  PENDING
  READY
  FAILED
}

enum SmsScene {
  REGISTER
  LOGIN
}

enum SmsVerificationStatus {
  SENT
  VERIFIED
  FAILED
}

model User {
  id                      String  @id @default(cuid())
  phoneNumber              String  @unique
  passwordHash           String?
  phoneVerifiedAt        DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  activeVoiceEnrollmentId String? @unique
}

model AnonymousUser {
  id                      String   @id @default(cuid())
  tokenHash               String   @unique
  expiresAt               DateTime
  lastSeenAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  activeVoiceEnrollmentId String?  @unique

  @@index([expiresAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, expiresAt])
}

model SmsVerification {
  id                 String                 @id @default(cuid())
  phoneNumber        String
  scene             SmsScene
  provider         String
  providerBizId    String?
  providerRequestId String?
  providerOutId    String
  codeHash         String?
  status           SmsVerificationStatus @default(SENT)
  verifyAttempts   Int                    @default(0)
  expiresAt       DateTime
  verifiedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([phoneNumber, scene, createdAt])
  @@index([status, expiresAt])
}

model VoiceEnrollment {
  id                String           @id @default(cuid())
  userId            String?
  anonymousUserId   String?
  status            EnrollmentStatus @default(PENDING)
  durationSeconds   Float
  originalFilename  String?
  inputContentType String
  voiceId           String?          @unique
  errorMessage     String?
  isInvalidated   Boolean          @default(false)
  bucket           String
  objectKey       String
  minioUri        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model TtsJob {
  id                 String          @id @default(cuid())
  userId             String?
  anonymousUserId    String?
  voiceEnrollmentId  String?
  voiceIdSnapshot   String
  text             String
  status           TtsJobStatus    @default(PENDING)
  outputContentType String?
  errorMessage    String?
  bucket          String?
  objectKey       String?
  minioUri       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
  @@index([voiceEnrollmentId])
}
