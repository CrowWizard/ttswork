generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

enum EnrollmentStatus {
  PENDING
  READY
  FAILED
}

enum TtsJobStatus {
  PENDING
  READY
  FAILED
}

enum SmsScene {
  REGISTER
  LOGIN
}

enum SmsVerificationStatus {
  SENT
  VERIFIED
  FAILED
}

model User {
  id                      String            @id @default(cuid())
  phoneNumber             String            @unique
  passwordHash            String?
  phoneVerifiedAt         DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  activeVoiceEnrollmentId String?           @unique
  activeVoiceEnrollment   VoiceEnrollment?  @relation("ActiveVoice", fields: [activeVoiceEnrollmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  voiceEnrollments        VoiceEnrollment[] @relation("UserVoiceEnrollments")
  ttsJobs                 TtsJob[]
  sessions                Session[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId, expiresAt])
}

model SmsVerification {
  id                String                @id @default(cuid())
  phoneNumber       String
  scene             SmsScene
  provider          String
  providerBizId     String?
  providerRequestId String?
  providerOutId     String
  codeHash          String?
  status            SmsVerificationStatus @default(SENT)
  verifyAttempts    Int                   @default(0)
  expiresAt         DateTime
  verifiedAt        DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([phoneNumber, scene, createdAt])
  @@index([status, expiresAt])
}

model VoiceEnrollment {
  id               String           @id @default(cuid())
  userId           String
  status           EnrollmentStatus @default(PENDING)
  durationSeconds  Float
  originalFilename String?
  inputContentType String
  voiceId          String?          @unique
  errorMessage     String?
  isInvalidated    Boolean          @default(false)
  bucket           String
  objectKey        String
  minioUri         String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation("UserVoiceEnrollments", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  activatedByUsers User[]           @relation("ActiveVoice")
  ttsJobs          TtsJob[]

  @@index([userId, createdAt])
}

model TtsJob {
  id                String          @id @default(cuid())
  userId            String
  voiceEnrollmentId String
  voiceIdSnapshot   String
  text              String
  status            TtsJobStatus    @default(PENDING)
  outputContentType String?
  errorMessage      String?
  bucket            String?
  objectKey         String?
  minioUri          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  voiceEnrollment   VoiceEnrollment @relation(fields: [voiceEnrollmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, createdAt])
  @@index([voiceEnrollmentId])
}
