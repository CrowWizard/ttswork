DATABASE_URL="postgresql://voice_mvp:your_password@127.0.0.1:5432/voice_mvp?schema=public"

MINIO_ENDPOINT="127.0.0.1"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="voice-mvp"
MINIO_CONSOLE_PORT="9001"

QWEN_MOCK_MODE="true"
QWEN_API_KEY=""
QWEN_ENROLL_URL=""
QWEN_TTS_URL=""

# 匿名 30 字免费试听使用的内置音色；登录用户仍使用自己建声后的 active voice。
QWEN_TRIAL_VOICE_ID="Cherry"

# 登录会话 Cookie 名称，浏览器会用这个 Cookie 保存登录态。
AUTH_SESSION_COOKIE_NAME="voice_session"

# 登录会话有效期，单位秒；2592000 秒约等于 30 天。
AUTH_SESSION_TTL_SECONDS="2592000"

# 会话活跃时间刷新间隔，单位秒；避免每个请求都写数据库。
AUTH_SESSION_TOUCH_INTERVAL_SECONDS="300"

# 是否只允许 HTTPS 发送 Cookie；本地 HTTP 开发通常保持 false，线上 HTTPS 建议 true。
COOKIE_SECURE="false"

# Cookie SameSite 策略；Lax 适合普通同站页面跳转，跨站嵌入场景才考虑 None。
COOKIE_SAME_SITE="Lax"

# 短信 Mock 开关；true 时不调用阿里云，接口会返回 debugCode 便于本地测试。
SMS_MOCK_MODE="true"

# 阿里云 AccessKey ID；SMS_MOCK_MODE=false 时必填。
SMS_ACCESS_KEY_ID=""

# 阿里云 AccessKey Secret；SMS_MOCK_MODE=false 时必填，禁止提交真实密钥。
SMS_ACCESS_KEY_SECRET=""

# 阿里云号码认证服务 Dypnsapi endpoint，国内默认 dypnsapi.aliyuncs.com。
SMS_ENDPOINT="dypnsapi.aliyuncs.com"

# 短信签名名称；需与阿里云号码认证服务控制台配置一致。
SMS_SIGN_NAME="速通互联验证码"

# 短信模板 Code；当前对应“登录/注册模板”。
SMS_TEMPLATE_CODE="100001"

# 短信模板变量；对应模板内容“您的验证码为${code}...以上验证码${min}分钟内有效”。
SMS_TEMPLATE_PARAM='{"code":"##code##","min":"5"}'

# 注册验证码方案名称；发送和校验必须使用同一个方案名称，短信登录即注册后通常与登录方案保持一致。
SMS_REGISTER_SCHEME_NAME="登录/注册模板"

# 登录验证码方案名称；发送和校验必须使用同一个方案名称。
SMS_LOGIN_SCHEME_NAME="登录/注册模板"

# 验证码长度，阿里云支持 4 到 8 位。
SMS_CODE_LENGTH="6"

# 验证码有效期，单位秒。
SMS_VALID_TIME_SECONDS="300"

# 同一手机号同一场景的发送间隔，单位秒，用于服务端频控。
SMS_INTERVAL_SECONDS="60"

# 验证码类型：1 纯数字；2 大写字母；3 小写字母；4 大小写；5 数字+大写；6 数字+小写；7 数字+大小写。
SMS_CODE_TYPE="1"

# 阿里云是否在发送响应中返回验证码；生产环境建议 false。
SMS_RETURN_VERIFY_CODE="false"

# 前台直接展示的通用使用码；注册用户免费机会用完后可输入该码继续生成。
USAGE_CODE_GENERAL_CODE="123456"
