generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

enum EnrollmentStatus {
  PENDING
  READY
  FAILED
}

enum RecordingStatus {
  UPLOADED
}

enum VoiceProfileKind {
  PURE
  SCENE
}

enum TtsJobStatus {
  PENDING
  READY
  FAILED
}

enum TtsAccessKind {
  FREE_TRIAL
  GENERAL_USAGE_CODE
  USAGE_CODE
}

enum UsageCodeModule {
  VOICE_TO_TEXT
}

enum SmsScene {
  REGISTER
  LOGIN
  PASSWORD_CHANGE
}

enum SmsVerificationStatus {
  SENT
  VERIFIED
  FAILED
}

model User {
  id                           String  @id @default(cuid())
  phoneNumber                  String  @unique
  passwordHash                 String?
  phoneVerifiedAt              DateTime?
  freeTtsUsedAt                DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  activePureVoiceEnrollmentId  String?  @unique
  activeSceneVoiceEnrollmentId String?  @unique
}

model AnonymousUser {
  id                           String   @id @default(cuid())
  tokenHash                    String   @unique
  expiresAt                    DateTime
  lastSeenAt                   DateTime @default(now())
  freeTtsUsedAt                DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  activePureVoiceEnrollmentId  String?  @unique
  activeSceneVoiceEnrollmentId String?  @unique

  @@index([expiresAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, expiresAt])
}

model SmsVerification {
  id                 String                 @id @default(cuid())
  phoneNumber        String
  scene             SmsScene
  provider         String
  providerBizId    String?
  providerRequestId String?
  providerOutId    String
  codeHash         String?
  status           SmsVerificationStatus @default(SENT)
  verifyAttempts   Int                    @default(0)
  expiresAt       DateTime
  verifiedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([phoneNumber, scene, createdAt])
  @@index([status, expiresAt])
}

model VoiceRecording {
  id              String          @id @default(cuid())
  userId          String?
  anonymousUserId String?
  status          RecordingStatus @default(UPLOADED)
  durationSeconds Float
  originalFilename String?
  inputContentType String
  bucket          String
  objectKey       String
  minioUri        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model VoiceEnrollment {
  id                String           @id @default(cuid())
  recordingId       String
  userId            String?
  anonymousUserId   String?
  profileKind       VoiceProfileKind
  status            EnrollmentStatus @default(PENDING)
  durationSeconds   Float
  originalFilename  String?
  inputContentType String
  voiceId           String?          @unique
  errorMessage     String?
  isInvalidated   Boolean          @default(false)
  bucket           String
  objectKey       String
  minioUri        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([recordingId])
  @@index([profileKind, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model UsageCode {
  id               String          @id @default(cuid())
  module           UsageCodeModule @default(VOICE_TO_TEXT)
  code             String          @unique
  consumedAt       DateTime?
  consumedByUserId String?
  consumedTtsJobId String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([module, consumedAt])
  @@index([consumedAt])
  @@index([consumedByUserId, consumedAt])
}

model TtsJob {
  id                 String          @id @default(cuid())
  userId             String?
  anonymousUserId    String?
  voiceEnrollmentId  String?
  profileKind        VoiceProfileKind
  accessKind         TtsAccessKind   @default(FREE_TRIAL)
  usageCodeId        String?         @unique
  usageCodeModule    UsageCodeModule?
  usageCodeValue     String?
  voiceIdSnapshot   String
  text             String
  sceneKey         String?
  instruction      String?
  status           TtsJobStatus    @default(PENDING)
  outputContentType String?
  errorMessage    String?
  bucket          String?
  objectKey       String?
  minioUri       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
  @@index([voiceEnrollmentId])
  @@index([accessKind, createdAt])
  @@index([usageCodeModule, createdAt])
}
