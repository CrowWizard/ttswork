generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

enum EnrollmentStatus {
  PENDING
  READY
  FAILED
}

enum RecordingStatus {
  UPLOADED
}

enum VoiceProfileKind {
  PURE
  SCENE
}

enum TtsJobStatus {
  PENDING
  READY
  FAILED
}

enum TtsAccessKind {
  FREE_TRIAL
  GENERAL_USAGE_CODE
  USAGE_CODE
  POINTS
}

enum PointTransactionType {
  REGISTER_BONUS
  USAGE_CODE_REDEEM
  TTS_CONSUME
}

enum UsageCodeModule {
  VOICE_TO_TEXT
}

enum VideoPlatform {
  BILIBILI
}

enum VideoInputType {
  URL
  BV
}

enum VideoSubtitleStatus {
  PENDING
  READY
  UNAVAILABLE
  FAILED
}

enum VideoTranscriptStatus {
  PENDING
  READY
  FAILED
}

enum VideoTranscriptSource {
  SUBTITLE
  ASR
}

enum VideoAnalysisJobStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum VideoAnalysisStage {
  SOURCE_LOAD
  SNAPSHOT_FETCH
  METADATA_SYNC
  TRANSCRIPT_RESOLVE
  ANALYSIS_PARAGRAPH_SUMMARY
  ANALYSIS_STRUCTURE
  ANALYSIS_SEMANTIC_PACKAGING
  ANALYSIS_FINAL_REPORT
  RESULT_WRITEBACK
  FAILED_WRITEBACK
}

enum VideoAnalysisStageEventStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum ContentGenerationType {
  VIDEO_SCRIPT
}

enum ContentGenerationTone {
  PERSONAL
  COMPANY
  PROFESSIONAL_CASUAL
}

enum ContentGenerationVerbosity {
  CONCISE
  DETAILED
}

enum ContentGenerationLanguage {
  ZH_CN
  EN_US
}

enum ContentGenerationPlatform {
  BILIBILI
  YOUTUBE
  XIAOHONGSHU
  DOUYIN
  WEIXIN_CHANNELS
  TWITTER
}

enum ContentGenerationDuration {
  SHORT
  MEDIUM
  LONG
}

enum ContentGenerationJobStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ContentGenerationStage {
  PREFERENCES
  DIRECTION_RESEARCH
  CATEGORY_MATCH
  STRUCTURE_DESIGN
  HOOK_GENERATION
  CONTENT_GENERATION
  FORMAT_VALIDATE
  RESULT_WRITEBACK
  FAILED_WRITEBACK
}

enum SmsScene {
  REGISTER
  LOGIN
  PASSWORD_CHANGE
}

enum SmsVerificationStatus {
  SENT
  VERIFIED
  FAILED
}

enum AnalyticsEventName {
  PAGE_VIEW
  REGISTER_SUCCESS
  VOICEPRINT_CREATED
  VOICE_GENERATED
  INVITE_CODE_USED
}

enum AnalyticsChannel {
  DIRECT
  REFERRAL
  ORGANIC
  SOCIAL
  PAID
  EMAIL
  UNKNOWN
}

model User {
  id              String    @id @default(cuid())
  phoneNumber     String    @unique
  passwordHash    String?
  phoneVerifiedAt DateTime?
  pointsBalance   Int       @default(0)
  freeTtsUsedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PointTransaction {
  id           String               @id @default(cuid())
  userId       String
  type         PointTransactionType
  delta        Int
  balanceAfter Int
  usageCodeId  String?
  ttsJobId     String?
  createdAt    DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([usageCodeId])
  @@index([ttsJobId])
}

model VoiceProfile {
  id                           String   @id @default(cuid())
  userId                       String?  @unique
  anonymousUserId              String?  @unique
  activePureVoiceEnrollmentId  String?
  activeSceneVoiceEnrollmentId String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([userId])
  @@index([anonymousUserId])
}

model AnonymousUser {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  expiresAt      DateTime
  lastSeenAt     DateTime  @default(now())
  freeTtsUsedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([expiresAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, expiresAt])
}

model SmsVerification {
  id                 String                 @id @default(cuid())
  phoneNumber        String
  scene             SmsScene
  provider         String
  providerBizId    String?
  providerRequestId String?
  providerOutId    String
  codeHash         String?
  status           SmsVerificationStatus @default(SENT)
  verifyAttempts   Int                    @default(0)
  expiresAt       DateTime
  verifiedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([phoneNumber, scene, createdAt])
  @@index([status, expiresAt])
}

model VoiceRecording {
  id              String          @id @default(cuid())
  userId          String?
  anonymousUserId String?
  status          RecordingStatus @default(UPLOADED)
  durationSeconds Float
  originalFilename String?
  inputContentType String
  bucket          String
  objectKey       String
  minioUri        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model VoiceEnrollment {
  id                String           @id @default(cuid())
  recordingId       String
  userId            String?
  anonymousUserId   String?
  profileKind       VoiceProfileKind
  status            EnrollmentStatus @default(PENDING)
  durationSeconds   Float
  originalFilename  String?
  inputContentType String
  voiceId           String?          @unique
  errorMessage     String?
  isInvalidated   Boolean          @default(false)
  bucket           String
  objectKey       String
  minioUri        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([recordingId])
  @@index([profileKind, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
}

model UsageCode {
  id               String          @id @default(cuid())
  module           UsageCodeModule @default(VOICE_TO_TEXT)
  code             String          @unique
  consumedAt       DateTime?
  consumedByUserId String?
  consumedTtsJobId String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([module, consumedAt])
  @@index([consumedAt])
  @@index([consumedByUserId, consumedAt])
}

model TtsJob {
  id                 String          @id @default(cuid())
  userId             String?
  anonymousUserId    String?
  voiceEnrollmentId  String?
  profileKind        VoiceProfileKind
  accessKind         TtsAccessKind   @default(FREE_TRIAL)
  usageCodeId        String?         @unique
  usageCodeModule    UsageCodeModule?
  usageCodeValue     String?
  voiceIdSnapshot   String
  text             String
  sceneKey         String?
  instruction      String?
  status           TtsJobStatus    @default(PENDING)
  outputContentType String?
  errorMessage    String?
  bucket          String?
  objectKey       String?
  minioUri       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([anonymousUserId, createdAt])
  @@index([voiceEnrollmentId])
  @@index([accessKind, createdAt])
  @@index([usageCodeModule, createdAt])
}

model AnalyticsVisitor {
  id               String   @id @default(cuid())
  anonymousId      String   @unique
  userId           String?
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  firstReferrer    String?
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstLandingPage String?

  @@index([userId])
  @@index([firstSeenAt])
  @@index([lastSeenAt])
}

model AnalyticsSession {
  id              String           @id @default(cuid())
  anonymousId     String
  userId          String?
  clientSessionId String?
  startedAt       DateTime         @default(now())
  endedAt         DateTime         @default(now())
  entryPage       String
  entryReferrer   String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  channel         AnalyticsChannel @default(UNKNOWN)

  @@index([anonymousId, startedAt])
  @@index([userId, startedAt])
  @@index([channel, startedAt])
  @@index([clientSessionId])
}

model AnalyticsEvent {
  id                 String             @id @default(cuid())
  anonymousId        String
  userId             String?
  analyticsSessionId String
  eventName          AnalyticsEventName
  url                String
  referrer           String?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  channel            AnalyticsChannel   @default(UNKNOWN)
  occurredAt         DateTime           @default(now())

  @@index([occurredAt])
  @@index([eventName, occurredAt])
  @@index([channel, occurredAt])
  @@index([userId, occurredAt])
  @@index([anonymousId, occurredAt])
}

model VideoSource {
  id                String                @id @default(cuid())
  platform          VideoPlatform         @default(BILIBILI)
  inputType         VideoInputType
  inputValue        String
  normalizedBvid    String                @unique
  normalizedUrl     String?
  title             String?
  authorName        String?
  authorMid         String?
  coverUrl          String?
  durationSeconds   Float?
  publishTime       DateTime?
  subtitleStatus    VideoSubtitleStatus   @default(PENDING)
  transcriptStatus  VideoTranscriptStatus @default(PENDING)
  transcriptSource  VideoTranscriptSource?
  subtitleText      String?
  transcriptText    String?
  fetchErrorMessage String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model VideoAnalysisJob {
  id                 String                        @id @default(cuid())
  userId             String
  videoSourceId      String
  status             VideoAnalysisJobStatus        @default(PENDING)
  errorMessage       String?
  currentStage       VideoAnalysisStage?
  currentStageStatus VideoAnalysisStageEventStatus?
  currentStageMessage String?
  currentStageStartedAt DateTime?
  summary            String?
  structureSections  String?
  highlights         String?
  copySuggestions    String?
  healthCard         String?
  packagingAnalysis  String?
  scriptAnalysis     String?
  semanticAnalysis   String?
  internalizationSummary String?
  metadataJson       String?
  modelName          String?
  promptVersion      String?
  workerId           String?
  lockedAt           DateTime?
  retryCount         Int                           @default(0)
  nextRetryAt        DateTime?
  completedAt        DateTime?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@index([userId, createdAt])
  @@index([videoSourceId, createdAt])
  @@index([status, createdAt])
  @@index([currentStage, currentStageStatus])
}

model VideoAnalysisJobStageEvent {
  id          String                        @id @default(cuid())
  jobId       String
  stage       VideoAnalysisStage
  status      VideoAnalysisStageEventStatus @default(RUNNING)
  message     String?
  detailsJson String?
  startedAt   DateTime                      @default(now())
  completedAt DateTime?
  durationMs  Int?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  @@index([jobId, createdAt])
  @@index([jobId, status, createdAt])
  @@index([stage, status, createdAt])
}

model ContentGenerationJob {
  id                    String                     @id @default(cuid())
  userId                String
  status                ContentGenerationJobStatus @default(PENDING)
  errorMessage          String?
  topicInput            String
  type                  ContentGenerationType      @default(VIDEO_SCRIPT)
  platform              ContentGenerationPlatform  @default(BILIBILI)
  language              ContentGenerationLanguage  @default(ZH_CN)
  tone                  ContentGenerationTone      @default(PERSONAL)
  verbosity             ContentGenerationVerbosity @default(CONCISE)
  duration              ContentGenerationDuration  @default(SHORT)
  generateShots         Boolean                    @default(true)
  heroOpening           String?
  outroClosing          String?
  category              String?
  matchedTopic          String?
  hook                  String?
  researchSummary       String?
  directionJson         String?
  structureJson         String?
  contentJson           String?
  finalJson             String?
  metadataJson          String?
  progressLogJson       String?
  modelName             String?
  promptVersion         String?
  workerId              String?
  lockedAt              DateTime?
  retryCount            Int                        @default(0)
  nextRetryAt           DateTime?
  currentStage          ContentGenerationStage?
  currentStageStatus    VideoAnalysisStageEventStatus?
  currentStageMessage   String?
  currentStageStartedAt DateTime?
  completedAt           DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([currentStage, currentStageStatus])
}

model ContentGenerationStageEvent {
  id          String                        @id @default(cuid())
  jobId       String
  stage       ContentGenerationStage
  status      VideoAnalysisStageEventStatus @default(RUNNING)
  label       String?
  message     String?
  detailsJson String?
  startedAt   DateTime                      @default(now())
  completedAt DateTime?
  durationMs  Int?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  @@index([jobId, createdAt])
  @@index([jobId, status, createdAt])
  @@index([stage, status, createdAt])
}
