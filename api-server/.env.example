# voice-mvp-api 环境变量（与根项目 .env 格式一致）
DATABASE_URL="postgresql://voice_mvp:your_password@127.0.0.1:5432/voice_mvp?schema=public"

MINIO_ENDPOINT="127.0.0.1"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="voice-mvp"
MINIO_PUBLIC_BASE_URL="http://127.0.0.1/minio"

QWEN_MOCK_MODE="true"
QWEN_API_KEY=""
QWEN_ENROLL_URL="https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization"
QWEN_TTS_URL="https://dashscope.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer"

PORT=3001
